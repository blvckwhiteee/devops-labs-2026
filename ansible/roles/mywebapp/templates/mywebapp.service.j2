[Unit]
Description=MyWebApp Notes Service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=app
Group=app
Restart=on-failure
RestartSec=5

ExecStartPre={{ app_bin_migrate }} \
    -db="{{ db_user }}:{{ db_password }}@tcp({{ hostvars['db01']['ansible_host'] }}:{{ db_port }})/{{ db_name }}?parseTime=true"

ExecStart={{ app_bin_server }} \
    -host=127.0.0.1 \
    -port={{ app_port }} \
    -db="{{ db_user }}:{{ db_password }}@tcp({{ hostvars['db01']['ansible_host'] }}:{{ db_port }})/{{ db_name }}?parseTime=true"

[Install]
WantedBy=multi-user.target
